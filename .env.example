# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/waren?schema=public"

# Application
APP_URL="http://localhost:3000"
APP_NAME="Waren"
NODE_ENV="development"

# Security
SESSION_COOKIE_NAME="sim_session"
# Put "false" for HTTP on the EC2 IP. Put "true" once HTTPS is enabled.
SESSION_COOKIE_SECURE="false"
SESSION_SECRET="change-me-with-at-least-32-random-characters"
EMAIL_TOKEN_PEPPER="change-me-with-at-least-32-random-characters"
CRON_SECRET="change-me-with-at-least-32-random-characters"
PASSWORD_MIN_LENGTH="12"

# Simulation
SIMULATED_FEE_BPS="5"
MARKET_DATA_PROVIDER="composite"
MARKET_DATA_CACHE_TTL_SECONDS="60"
MARKET_DATA_HISTORY_CACHE_TTL_SECONDS="900"
MARKET_NEWS_CACHE_TTL_SECONDS="900"
MARKET_DATA_HTTP_TIMEOUT_MS="9000"
ALPHA_VANTAGE_API_KEY=""
COINGECKO_API_KEY=""
COINGECKO_API_BASE_URL="https://api.coingecko.com/api/v3"

# SMTP. If SMTP_HOST is empty, emails are logged to the server console in development.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Waren <no-reply@example.com>"

# Jobs
DAILY_SUMMARY_DEFAULT_TIMEZONE="Europe/Paris"
