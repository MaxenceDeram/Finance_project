[Unit]
Description=Waren Next.js application on AWS EC2
After=network.target

[Service]
Type=simple
User=waren
Group=waren
WorkingDirectory=/var/www/waren
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=HOSTNAME=0.0.0.0
EnvironmentFile=/var/www/waren/.env
ExecStart=/usr/bin/npm run start:prod
Restart=always
RestartSec=10
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/www/waren

[Install]
WantedBy=multi-user.target
