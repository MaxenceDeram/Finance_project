[Unit]
Description=Waren daily summary job
After=network.target waren.service

[Service]
Type=oneshot
User=waren
Group=waren
WorkingDirectory=/var/www/waren
Environment=NODE_ENV=production
EnvironmentFile=/var/www/waren/.env.production
ExecStart=/usr/bin/npm run job:daily-summary
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/www/waren
