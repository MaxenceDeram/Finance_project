generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AssetType {
  STOCK
  ETF
  CRYPTO
  INDEX
  FUND
  OTHER
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP
  TAKE_PROFIT
  TRAILING_STOP
}

enum OrderStatus {
  PENDING
  FILLED
  PARTIALLY_FILLED
  CANCELLED
  REJECTED
}

enum CashLedgerType {
  INITIAL_DEPOSIT
  TRADE_BUY
  TRADE_SELL
  FEE
  ADJUSTMENT
  DIVIDEND
}

enum DailyEmailStatus {
  SENT
  SKIPPED
  FAILED
}

enum UserRole {
  USER
  ADMIN
  OWNER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum AuditAction {
  REGISTER
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  EMAIL_CONFIRMED
  EMAIL_CONFIRMATION_RESENT
  PORTFOLIO_CREATED
  PORTFOLIO_UPDATED
  PORTFOLIO_DELETED
  ORDER_PLACED
  PROFILE_EMAIL_CHANGE_REQUESTED
  PROFILE_PASSWORD_CHANGED
  ADMIN_CONFIRMATION_RESENT
  ADMIN_USER_ROLE_UPDATED
  ADMIN_USER_STATUS_UPDATED
  ADMIN_DAILY_JOB_TRIGGERED
  DAILY_EMAIL_SENT
  DAILY_EMAIL_FAILED
}

model User {
  id                 String                   @id @default(cuid())
  email              String                   @unique
  passwordHash       String
  role               UserRole                 @default(USER)
  status             UserStatus               @default(ACTIVE)
  emailVerified      Boolean                  @default(false)
  emailVerifiedAt    DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  preferences        UserPreferences?
  verificationTokens EmailVerificationToken[]
  sessions           Session[]
  portfolios         Portfolio[]
  dailyEmailLogs     DailyEmailLog[]
  auditLogs          AuditLog[]

  @@index([emailVerified])
  @@index([role])
  @@index([status])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([usedAt])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  userAgent  String?
  ipHash     String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserPreferences {
  userId            String   @id
  dailyEmailEnabled Boolean  @default(true)
  timezone          String   @default("Europe/Paris")
  preferredCurrency String   @default("EUR")
  dailyEmailHour    Int      @default(22)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Portfolio {
  id              String                @id @default(cuid())
  userId          String
  name            String
  baseCurrency    String
  initialCash     Decimal               @db.Decimal(18, 4)
  description     String?
  strategy        String?
  benchmarkSymbol String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashLedger      PortfolioCashLedger[]
  orders          Order[]
  positions       Position[]
  snapshots       PortfolioSnapshot[]
  dailyEmailLogs  DailyEmailLog[]

  @@index([userId])
  @@index([benchmarkSymbol])
}

model PortfolioCashLedger {
  id          String         @id @default(cuid())
  portfolioId String
  type        CashLedgerType
  amount      Decimal        @db.Decimal(18, 4)
  currency    String
  note        String?
  createdAt   DateTime       @default(now())
  portfolio   Portfolio      @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, createdAt])
  @@index([type])
}

model Asset {
  id           String       @id @default(cuid())
  symbol       String
  name         String
  assetType    AssetType
  exchange     String?
  currency     String
  sector       String?
  country      String?
  isin         String?
  provider     String?
  providerId   String?
  exchangeName String?
  industry     String?
  description  String?
  logoUrl      String?
  website      String?
  marketCap    Decimal?     @db.Decimal(24, 4)
  lastSyncedAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  prices       AssetPrice[]
  news         MarketNews[]
  orders       Order[]
  positions    Position[]

  @@unique([symbol, exchange, currency])
  @@index([assetType])
  @@index([symbol])
  @@index([provider, providerId])
  @@index([isin])
}

model AssetPrice {
  id        String   @id @default(cuid())
  assetId   String
  timestamp DateTime
  open      Decimal? @db.Decimal(18, 6)
  high      Decimal? @db.Decimal(18, 6)
  low       Decimal? @db.Decimal(18, 6)
  close     Decimal  @db.Decimal(18, 6)
  volume    Decimal? @db.Decimal(24, 4)
  createdAt DateTime @default(now())
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, timestamp])
  @@index([assetId, timestamp])
}

model Order {
  id              String      @id @default(cuid())
  portfolioId     String
  assetId         String
  side            OrderSide
  orderType       OrderType
  quantity        Decimal     @db.Decimal(24, 8)
  requestedPrice  Decimal?    @db.Decimal(18, 6)
  status          OrderStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  portfolio       Portfolio   @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset           Asset       @relation(fields: [assetId], references: [id], onDelete: Restrict)
  executions      Execution[]

  @@index([portfolioId, createdAt])
  @@index([assetId])
  @@map("orders")
}

model Execution {
  id               String   @id @default(cuid())
  orderId          String
  executedPrice    Decimal  @db.Decimal(18, 6)
  executedQuantity Decimal  @db.Decimal(24, 8)
  fees             Decimal  @default(0) @db.Decimal(18, 4)
  realizedPnl      Decimal  @default(0) @db.Decimal(18, 4)
  executedAt       DateTime @default(now())
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([executedAt])
}

model Position {
  id          String    @id @default(cuid())
  portfolioId String
  assetId     String
  quantity    Decimal   @db.Decimal(24, 8)
  averageCost Decimal   @db.Decimal(18, 6)
  openedAt    DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@unique([portfolioId, assetId])
  @@index([portfolioId])
}

model PortfolioSnapshot {
  id                 String    @id @default(cuid())
  portfolioId        String
  snapshotDate       DateTime
  totalValue         Decimal   @db.Decimal(18, 4)
  cashValue          Decimal   @db.Decimal(18, 4)
  investedValue      Decimal   @db.Decimal(18, 4)
  unrealizedPnl      Decimal   @db.Decimal(18, 4)
  realizedPnl        Decimal   @db.Decimal(18, 4)
  dailyChangeAmount  Decimal?  @db.Decimal(18, 4)
  dailyChangePercent Decimal?  @db.Decimal(12, 6)
  createdAt          DateTime  @default(now())
  portfolio          Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, snapshotDate])
  @@index([snapshotDate])
}

model DailyEmailLog {
  id          String           @id @default(cuid())
  userId      String
  portfolioId String?
  periodDate  DateTime
  sentAt      DateTime         @default(now())
  status      DailyEmailStatus
  subject     String
  error       String?
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio   Portfolio?       @relation(fields: [portfolioId], references: [id], onDelete: SetNull)

  @@unique([userId, portfolioId, periodDate])
  @@index([userId, sentAt])
  @@index([status])
}

model MarketNews {
  id          String   @id @default(cuid())
  assetId     String?
  symbol      String?
  provider    String
  externalId  String?
  title       String
  summary     String?
  source      String?
  url         String?
  imageUrl    String?
  sentiment   String?
  publishedAt DateTime
  fetchedAt   DateTime @default(now())
  asset       Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@unique([provider, externalId])
  @@index([assetId, publishedAt])
  @@index([symbol, publishedAt])
  @@index([publishedAt])
}

model MarketDataCache {
  id        String   @id @default(cuid())
  key       String   @unique
  provider  String
  payload   Json
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@index([provider])
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  metadata  Json?
  ipHash    String?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
}
