generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DailyEmailStatus {
  SENT
  SKIPPED
  FAILED
}

enum EmailProvider {
  CONSOLE
  SMTP
  SES
}

enum EmailLogStatus {
  SENT
  FAILED
}

enum EmailCategory {
  EMAIL_CONFIRMATION
  DAILY_SUMMARY
  APPLICATION_FOLLOW_UP
}

enum UserRole {
  USER
  ADMIN
  OWNER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum AuditAction {
  REGISTER
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  EMAIL_CONFIRMED
  EMAIL_CONFIRMATION_RESENT
  PORTFOLIO_CREATED
  PORTFOLIO_UPDATED
  PORTFOLIO_DELETED
  ORDER_PLACED
  PROFILE_EMAIL_CHANGE_REQUESTED
  PROFILE_PASSWORD_CHANGED
  ADMIN_CONFIRMATION_RESENT
  ADMIN_USER_ROLE_UPDATED
  ADMIN_USER_STATUS_UPDATED
  ADMIN_DAILY_JOB_TRIGGERED
  DAILY_EMAIL_SENT
  DAILY_EMAIL_FAILED
  APPLICATION_CREATED
  APPLICATION_UPDATED
  APPLICATION_DELETED
  APPLICATION_DOCUMENT_UPLOADED
  APPLICATION_DOCUMENT_DELETED
  PROFILE_AVATAR_UPDATED
  PROFILE_AVATAR_REMOVED
  FOLLOW_UP_EMAIL_SENT
  FOLLOW_UP_TEMPLATE_CREATED
  FOLLOW_UP_TEMPLATE_UPDATED
  FOLLOW_UP_TEMPLATE_DELETED
}

enum ContractType {
  INTERNSHIP
  APPRENTICESHIP
  FULL_TIME
  PART_TIME
  FREELANCE
  TEMPORARY
  OTHER
}

enum ApplicationStatus {
  TO_APPLY
  APPLIED
  FOLLOW_UP_SENT
  HR_INTERVIEW
  TECHNICAL_INTERVIEW
  CASE_STUDY
  OFFER_RECEIVED
  REJECTED
  ACCEPTED
}

enum ApplicationDocumentType {
  RESUME
  COVER_LETTER
  OTHER
}

model User {
  id                 String                   @id @default(cuid())
  email              String                   @unique
  displayName        String?
  passwordHash       String
  role               UserRole                 @default(USER)
  status             UserStatus               @default(ACTIVE)
  emailVerified      Boolean                  @default(false)
  emailVerifiedAt    DateTime?
  avatarStorageKey   String?
  avatarMimeType     String?
  avatarUpdatedAt    DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  preferences        UserPreferences?
  verificationTokens EmailVerificationToken[]
  sessions           Session[]
  jobApplications    JobApplication[]
  applicationDocs    ApplicationDocument[]
  dailyEmailLogs     DailyEmailLog[]
  emailTemplates     EmailTemplate[]
  emailLogs          EmailLog[]
  auditLogs          AuditLog[]

  @@index([emailVerified])
  @@index([role])
  @@index([status])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([usedAt])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  userAgent  String?
  ipHash     String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserPreferences {
  userId            String   @id
  dailyEmailEnabled Boolean  @default(true)
  timezone          String   @default("Europe/Paris")
  dailyEmailHour    Int      @default(22)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobApplication {
  id              String                @id @default(cuid())
  userId          String
  companyName     String
  roleTitle       String
  contractType    ContractType
  location        String?
  applicationDate DateTime?
  status          ApplicationStatus     @default(TO_APPLY)
  listingUrl      String?
  hrContact       String?
  contactEmail    String?
  compensation    String?
  notes           String?
  followUpDate    DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents       ApplicationDocument[]
  emailLogs       EmailLog[]

  @@index([userId, status, applicationDate])
  @@index([userId, followUpDate])
  @@index([companyName])
}

model ApplicationDocument {
  id               String                  @id @default(cuid())
  applicationId    String
  userId           String
  documentType     ApplicationDocumentType
  originalFilename String
  storageKey       String                  @unique
  mimeType         String
  sizeBytes        Int
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  application      JobApplication          @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([applicationId, documentType, createdAt])
  @@index([userId, createdAt])
}

model DailyEmailLog {
  id         String           @id @default(cuid())
  userId     String
  periodDate DateTime
  sentAt     DateTime         @default(now())
  status     DailyEmailStatus
  subject    String
  error      String?
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodDate])
  @@index([userId, sentAt])
  @@index([status])
}

model EmailTemplate {
  id              String     @id @default(cuid())
  userId          String
  name            String
  subjectTemplate String
  bodyTemplate    String
  isDefault       Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailLogs       EmailLog[]

  @@index([userId, createdAt])
}

model EmailLog {
  id                String         @id @default(cuid())
  userId            String
  applicationId     String?
  templateId        String?
  category          EmailCategory
  provider          EmailProvider
  status            EmailLogStatus
  toEmail           String
  fromEmail         String
  subject           String
  htmlBody          String
  textBody          String
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime       @default(now())
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  application       JobApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  template          EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([applicationId, createdAt])
  @@index([category, createdAt])
  @@index([status, createdAt])
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  metadata  Json?
  ipHash    String?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
}
